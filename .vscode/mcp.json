{
	"servers": {
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.0.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"hostinger-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": ["hostinger-api-mcp@latest"],
			"env": {
				"API_TOKEN": "${input:hostinger_api_token}"
			}
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		},
		{
			"id": "hostinger_api_token",
			"type": "promptString",
			"description": "Hostinger API token",
			"password": true
		}
	]
}