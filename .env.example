NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Mapbox destination autocomplete. Without it, the propose
# field falls back to a plain text input.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: AI draft ("Lock & draft") beta feature. Both keys
# required to enable. Without them, the AI CTA is hidden.
# - GEMINI_API_KEY: from https://aistudio.google.com/apikey
# - GOOGLE_PLACES_API_KEY: from a GCP project with Places API (New)
#   enabled + billing attached
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GOOGLE_PLACES_API_KEY=

# Email that can access /ai-usage (owner-only cost telemetry).
AI_BETA_OWNER_EMAIL=

# Stripe (Crew Plus billing). Both required for the webhook handler at
# /api/stripe/webhook to work. Without them, subscription state changes
# won't sync into profiles.stripe_subscription_status.
# - STRIPE_SECRET_KEY: dashboard → Developers → API keys
# - STRIPE_WEBHOOK_SECRET: dashboard → Developers → Webhooks → endpoint
#   For local dev, use `stripe listen --forward-to
#   localhost:3000/api/stripe/webhook` and copy the printed `whsec_...`
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Crew Plus monthly price (live mode default if unset). Override per env
# if you ever introduce annual or test-mode prices. Public-ish: just the
# ID, not a secret. Defaults in code to the live Crew Plus price.
STRIPE_PRICE_ID=
# Founding tier annual subscription price (£179 / year). Required by the
# Founding fast lane checkout at /curated/[slug]/founding-checkout —
# without it the action returns "Founding checkout is not configured."
# Create the price in the Stripe dashboard and paste the price ID here.
STRIPE_FOUNDING_PRICE_ID=

# Playwright auth setup
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_TRIP_SLUG=

# SerpApi (Google Flights live pricing for the trip budget block)
# Sign up at https://serpapi.com — free 100 searches/month
SERPAPI_KEY=

# Salt for hashing visitor IPs in the curated-trip teaser flow. Required by
# the submitTeaserForm action; missing salt raises at request time. Generate
# with: `openssl rand -hex 32`. Must be set in Vercel before deploy.
IP_HASH_SALT=

# Optional. From-address used for the teaser confirmation + day-7 nudge
# emails sent by the curated-trip flow. Falls back to
# "Tripcrew <hello@tripcrew.app>" when unset.
TEASER_EMAIL_FROM=

# CLI-only, not read by the app
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Vercel BotID — invisible bot detection on the curated-teaser submit.
# No env vars: Basic mode is free and auto-wired by `botid/next/config`
# in next.config.ts + initBotId() in instrumentation-client.ts. Deep
# Analysis (paid) is opted in via the Vercel dashboard:
#   Project → Firewall → Rules → "Vercel BotID Deep Analysis".
# Local dev always classifies as human; production-only protection.

# Shared secret for the application-review cron at
# /api/cron/finalise-applications. The Vercel scheduler must send
# `Authorization: Bearer ${CRON_SECRET}` on every invocation. Generate
# with: `openssl rand -hex 32`. Without it, the cron route returns 500.
CRON_SECRET=
